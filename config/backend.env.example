APP_NAME="CareerPilot AI"
APP_VERSION="0.1.0"
API_PREFIX="/api/v1"
ENVIRONMENT=development
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"
JWT_SECRET_KEY="your-secret-key-here"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
OLLAMA_BASE_URL="http://localhost:11434"
CORS_ORIGINS='["http://localhost:3000"]'
LOG_LEVEL="INFO"
STORAGE_PROVIDER=LOCAL
LOCAL_STORAGE_PATH=storage/resumes
MAX_FILE_SIZE_MB=5
SPACY_MODEL="en_core_web_sm"
PARSER_VERSION="v1"
MAX_PAGES=10
MAX_TEXT_LENGTH=200000

# ATS settings
ATS_MIN_SKILLS_FOR_FULL_SCORE=8
ATS_MIN_EXPERIENCE_ENTRIES=2
ATS_RECOMMENDATION_LIMIT=8

# Job Match settings
JOB_MATCH_MIN_SKILLS=5
JOB_MATCH_MAX_RECOMMENDATIONS=10
JOB_MATCH_KEYWORD_LIMIT=100
JOB_MATCH_VERSION=v1

# AI Foundation settings
AI_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
AI_TEMPERATURE=0.3
AI_TOP_P=0.9
AI_MAX_TOKENS=2048
AI_TIMEOUT=60
AI_RETRY_COUNT=3
PROMPT_CACHE_ENABLED=true
PROMPT_CACHE_TTL=300
PROMPT_TEMPLATE_PATH=app/ai/prompts/templates

# Cover Letter settings
COVER_LETTER_DEFAULT_STYLE="PROFESSIONAL"
COVER_LETTER_DEFAULT_MODE="STANDARD"
COVER_LETTER_MAX_LENGTH=4000

# AI Interview settings
INTERVIEW_DEFAULT_TYPE="BEHAVIORAL"
INTERVIEW_DEFAULT_DIFFICULTY="MEDIUM"
INTERVIEW_MAX_QUESTIONS=15
INTERVIEW_MAX_SESSION_MINUTES=60
INTERVIEW_PROMPT_VERSION="1.0.0"
INTERVIEW_CONTEXT_CACHE=true
INTERVIEW_WORKFLOW_VERSION="1.0.0"

# AI Career Roadmap settings
ROADMAP_DEFAULT_MONTHS=12
ROADMAP_DEFAULT_PHASES=3
ROADMAP_MAX_MILESTONES=15
ROADMAP_PROMPT_VERSION="1.0.0"
ROADMAP_CONTEXT_CACHE=true
ROADMAP_WORKFLOW_VERSION="1.0.0"




